local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/hakaiofc/Base/main/HUBORION"))()

local Window = OrionLib:MakeWindow({
    Name = "HaKai OFC",
    HidePremium = false,
    SaveConfig = true,
    ConfigFolder = "OrionTest",
    IntroEnabled = false
})

pcall(function()
    local VirtualUser = game:GetService("VirtualUser")
    game:GetService("Players").LocalPlayer.Idled:Connect(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)
end)

local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local Dumbell = Remotes:WaitForChild("Dumbell")
local BenchRemote = Remotes:WaitForChild("Bench")
local PushUpRemote = Remotes:WaitForChild("PushUp")
local DoubleReg = Remotes:WaitForChild("DoubleReg")

_G.BILLS_OFC = false
_G.AutoBench = false
_G.AutoForça = false

local ENVIO_POR_FRAME = 3
local INTERVALO_TEMPO = 0.01384
local acumulador = 0

local function AutoDumbell()
    while _G.BILLS_OFC do
        pcall(function()
            Dumbell:FireServer("Rep", 3)
        end)
        task.wait() 
    end
end

RunService.Heartbeat:Connect(function()
    if _G.AutoBench then
        pcall(function()
            for i = 1, ENVIO_POR_FRAME do
                BenchRemote:FireServer(true)
                BenchRemote:FireServer(true)
                BenchRemote:FireServer(true)
                PushUpRemote:FireServer(true)
                BenchRemote:FireServer(true)
                PushUpRemote:FireServer(true)
                PushUpRemote:FireServer(true)
            end
        end)
    end
end)

RunService.Heartbeat:Connect(function(deltaTime)
    if _G.AutoForça then
        acumulador = acumulador + deltaTime
        if acumulador >= INTERVALO_TEMPO then
            acumulador = acumulador - INTERVALO_TEMPO
            
            pcall(function()
                for i = 1, 3 do
                    DoubleReg:FireServer()
                    DoubleReg:FireServer()
                    DoubleReg:FireServer()
                end
                Dumbell:FireServer("Rep", 3)
            end)
        end
    end
end)

local FarmTab = Window:MakeTab({
    Name = "FarmStrength",
    Icon = "rbxassetid://4483345998",
    PremiumOnly = false
})

FarmTab:AddToggle({
    Name = "Auto Dumbell",
    Default = false,
    Callback = function(v)
        _G.BILLS_OFC = v
        if v then 
            task.spawn(AutoDumbell) 
        end
    end
})

FarmTab:AddToggle({
    Name = "Farm Força",
    Default = false,
    Callback = function(v)
        _G.AutoForça = v
    end
})

FarmTab:AddToggle({
    Name = "Auto Bench",
    Default = false,
    Callback = function(v)
        _G.AutoBench = v
    end
})

OrionLib:Init()

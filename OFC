_G.BILLS_OFC = false
_G.AutoStr = false
_G.AutoBench = false

local function AutoDumbell()
    while _G.BILLS_OFC do 
        task.wait()
        if _G.BILLS_OFC == false then return end
        
        local A_1 = "Rep"
        local A_2 = 3
        
        if _G.BILLS_OFC == true then
            pcall(function()
                game:GetService("ReplicatedStorage").Remotes.Dumbell:FireServer(A_1, A_2)
            end)
        end
    end
end

local RunService = game:GetService("RunService")
local Heartbeat = RunService.Heartbeat
local INTERVALO_TEMPO_HB = 0.01384
local acumulador = 0

Heartbeat:Connect(function(deltaTime)
    if _G.AutoStr then
        acumulador = acumulador + deltaTime
        if acumulador >= INTERVALO_TEMPO_HB then
            acumulador = acumulador - INTERVALO_TEMPO_HB
            pcall(function()
                local Remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                if Remotes then
                    local DoubleReg = Remotes:FindFirstChild("DoubleReg")
                    local Dumbell = Remotes:FindFirstChild("Dumbell")
                    if DoubleReg and Dumbell then
                        for i = 1, 3 do
                            DoubleReg:FireServer()
                            DoubleReg:FireServer()
                            DoubleReg:FireServer()
                        end
                        Dumbell:FireServer("Rep", 3)
                    end
                end
            end)
        end
    end
end)

local ENVIO_POR_FRAME = 3

Heartbeat:Connect(function()
    if _G.AutoBench then
        pcall(function()
            local Remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
            if Remotes then
                local BenchRemote = Remotes:FindFirstChild("Bench")
                local PushUpRemote = Remotes:FindFirstChild("PushUp")
                if BenchRemote and PushUpRemote then
                    for i = 1, ENVIO_POR_FRAME do
                        BenchRemote:FireServer(true)
                        BenchRemote:FireServer(true)
                        BenchRemote:FireServer(true)
                        PushUpRemote:FireServer(true)
                        BenchRemote:FireServer(true)
                        PushUpRemote:FireServer(true)
                        PushUpRemote:FireServer(true)
                    end
                end
            end
        end)
    end
end)

